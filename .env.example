# -- Public endpoint advertised to clients via /cookie ------------------------
RELAY_PUBLIC_HOST=ssh-relay.example.com
RELAY_PUBLIC_PORT=443

# -- Identity provider: none | cloudflare-access | gcp-iap --------------------
RELAY_IDENTITY_PROVIDER=none
RELAY_AUTH_REQUIRED=true

# Cloudflare Access (when RELAY_IDENTITY_PROVIDER=cloudflare-access)
# RELAY_CF_TEAM_DOMAIN=yourteam
# RELAY_CF_AUDIENCE=replace-with-application-aud-from-cloudflare-access

# GCP IAP (when RELAY_IDENTITY_PROVIDER=gcp-iap)
# Example audience for a GCE backend: /projects/NUMBER/global/backendServices/ID
# RELAY_IAP_AUDIENCE=/projects/123/global/backendServices/456

# -- Session tuning -----------------------------------------------------------
# RELAY_READ_CHUNK_BYTES=65536
# RELAY_MAX_FRAME_BYTES=1048576
# RELAY_MAX_REPLAY_BUFFER=4194304
# RELAY_GRACE_SECONDS=120

# -- Source-port binding (PAN User-ID) ----------------------------------------
# Unset to let the kernel pick source ports. When set, each session holds one
# port from this range so PAN can map (relay_ip, port) -> user.
# RELAY_SOURCE_PORT_MIN=40000
# RELAY_SOURCE_PORT_MAX=49999
# RELAY_RELAY_IP=203.0.113.10

# -- Log sinks: comma-separated {stderr, file, splunk, pan} -------------------
RELAY_LOG_SINKS=stderr

# File sink
# RELAY_LOG_FILE_PATH=/var/log/ssh-relay/audit.jsonl
# RELAY_LOG_FILE_MAX_BYTES=104857600
# RELAY_LOG_FILE_BACKUP_COUNT=10

# Splunk HEC
# RELAY_SPLUNK_URL=https://splunk.example.com:8088
# RELAY_SPLUNK_TOKEN=00000000-0000-0000-0000-000000000000
# RELAY_SPLUNK_INDEX=ssh_relay
# RELAY_SPLUNK_SOURCE=ssh-relay
# RELAY_SPLUNK_SOURCETYPE=_json
# RELAY_SPLUNK_VERIFY=true

# Palo Alto Networks User-ID XML API
# RELAY_PAN_FIREWALL_URLS=https://fw1.example.com,https://fw2.example.com
# RELAY_PAN_API_KEY=your-pan-api-key
# RELAY_PAN_VERIFY=true
# RELAY_PAN_LOGIN_TIMEOUT_SECONDS=0
